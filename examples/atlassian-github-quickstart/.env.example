# ── Slack ────────────────────────────────────────────────────────────────────
# Create a bot at https://api.slack.com/apps → "OAuth & Permissions"
# Required scopes: chat:write, channels:history, channels:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# ── Confluence ────────────────────────────────────────────────────────────────
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_USER_EMAIL=you@yourcompany.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki

# ── Jira ──────────────────────────────────────────────────────────────────────
# Same API token as Confluence (Atlassian account token is shared)
JIRA_USER_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BASE_URL=https://yourorg.atlassian.net

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (classic): https://github.com/settings/tokens
# Required scopes: repo, project (for Projects v2)
GITHUB_TOKEN=ghp_your-token-here

# ── Project config (used by the workflow) ─────────────────────────────────────
JIRA_PROJECT_KEY=MYPROJ
GITHUB_REPO_OWNER=your-github-org
GITHUB_REPO_NAME=your-repo
SLACK_NOTIFY_CHANNEL=#ai-sdd-notifications
CONFLUENCE_SPACE_KEY=MYSPACE
